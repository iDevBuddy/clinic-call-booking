# ============================================
# Retell AI Configuration
# ============================================
# Get your API key from: https://dashboard.retellai.com
RETELL_API_KEY=your_retell_api_key_here

# ============================================
# Airtable Configuration
# ============================================
# Get your API key from: https://airtable.com/create/tokens
# (Create a Personal Access Token with data.records:read and data.records:write scopes)
AIRTABLE_API_KEY=your_airtable_personal_access_token_here

# Your Airtable Base ID (starts with "app...")
# Find it at: https://airtable.com/developers/web/api/introduction
AIRTABLE_BASE_ID=your_airtable_base_id_here

# The name of your Appointments table in Airtable
AIRTABLE_TABLE_NAME=Appointments

# ============================================
# Server Configuration
# ============================================
PORT=3000

# ============================================
# Clinic Configuration
# ============================================
# Clinic operating hours (24-hour format)
CLINIC_OPEN_HOUR=9
CLINIC_CLOSE_HOUR=17

# Appointment duration in minutes
APPOINTMENT_DURATION=30

# Clinic name (used by the AI agent)
CLINIC_NAME=My Dental Clinic
